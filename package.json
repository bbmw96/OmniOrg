  ],
  "license": "MIT",
  "scripts": {
    "server": "npx ts-node api/server.ts",
    "dashboard": "cd dashboard && npm run dev",
    "mesh:status": "npx ts-node -e \"const {mesh}=require('./core/neuromesh/mesh'); console.log(JSON.stringify(mesh.getHealthReport(),null,2))\"",
    "content:run": "node --max-old-space-size=4096 -r ts-node/register scripts/run-content-engine.ts",
    "install:all": "npm install && cd dashboard && npm install",
    "typecheck": "npx tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.123",
    "@anthropic-ai/sdk": "^0.92.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
