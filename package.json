{
  "name": "omniorg",
  "version": "2.0.0",
  "description": "OmniOrg: NEUROMESH™ Enterprise AI. 20,000+ Specialist Agents. Proprietary Engine. Multi-tenant. Ready for any company worldwide.",
  "author": "BBMW0 Technologies <hello@bbmw0.com> (https://bbmw0.com)",
  "homepage": "https://bbmw0.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/BBMW0/OmniOrg.git"
  },
  "keywords": [
    "ai",
    "agents",
    "enterprise",
    "neuromesh",
    "omniorg",
    "bbmw0"
  ],
  "license": "MIT",
  "scripts": {
    "server": "npx ts-node api/server.ts",
    "dashboard": "cd dashboard && npm run dev",
    "mesh:status": "npx ts-node -e \"const {mesh}=require('./core/neuromesh/mesh'); console.log(JSON.stringify(mesh.getHealthReport(),null,2))\"",
    "content:run": "node --max-old-space-size=4096 -r ts-node/register scripts/run-content-engine.ts",
    "bbm0902:weekly": "node --max-old-space-size=4096 -r ts-node/register scripts/run-bbm0902-weekly.ts",
    "bbm0902:influencer": "node --max-old-space-size=4096 -r ts-node/register -e \"require('./intelligence/content/bbm0902-influencer-engine').bbm0902Engine.generateInfluencerShort().then(r=>console.log(JSON.stringify(r,null,2)))\"",
    "daemon:start": "node --max-old-space-size=4096 -r ts-node/register scripts/start-agent-daemon.ts",
    "daemon:install": "node --max-old-space-size=4096 -r ts-node/register scripts/start-agent-daemon.ts install",
    "daemon:uninstall": "node --max-old-space-size=4096 -r ts-node/register scripts/start-agent-daemon.ts uninstall",
    "game:generate": "node --max-old-space-size=4096 -r ts-node/register scripts/setup-game-scheduler.ts",
    "game:schedule": "node --max-old-space-size=4096 -r ts-node/register scripts/setup-game-scheduler.ts",
    "ifc:validate": "node --max-old-space-size=4096 -r ts-node/register scripts/ifc-validate-cli.ts",
    "install:all": "npm install && cd dashboard && npm install",
    "typecheck": "npx tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.123",
    "@anthropic-ai/sdk": "^0.92.0",
    "@google/generative-ai": "^0.24.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/uuid": "^10.0.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.6.1",
    "node-windows": "^1.0.0-beta.8",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
