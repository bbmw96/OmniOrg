{
  "name": "omniorg",
  "version": "2.0.0",
  "description": "OmniOrg: NEUROMESH™ Enterprise AI. 20,000+ Specialist Agents. Proprietary Engine. Multi-tenant. Ready for any company worldwide.",
  "author": "BBMW0 Technologies <hello@bbmw0.com> (https://bbmw0.com)",
  "homepage": "https://bbmw0.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/BBMW0/OmniOrg.git"
  },
  "keywords": [
    "ai",
    "agents",
    "enterprise",
    "neuromesh",
    "omniorg",
