{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "agents/**/*",
    "api/**/*",
    "config/**/*",
    "core/**/*",
    "intelligence/**/*",
    "marketplace/**/*",
    "observability/**/*",
    "scripts/**/*",
    "tenancy/**/*",
    "tools/**/*",
    "*.ts"
  ],
  "exclude": ["node_modules", "dashboard", "dist"]
}
